<?xml version="1.0" encoding="utf-8"?>
<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <CNCGZH_DEP_DXSDK Condition="'$(CNCGZH_DEP_DXSDK)'==''">$([System.Environment]::GetEnvironmentVariable('CNCGZH_DEP_DXSDK'))</CNCGZH_DEP_DXSDK>
