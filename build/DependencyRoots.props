    <CNCGZH_DEP_LZH_HDR Condition="'$(CNCGZH_DEP_LZH_HDR)'==''">$([System.Environment]::GetEnvironmentVariable('CNCGZH_DEP_LZH_HDR'))</CNCGZH_DEP_LZH_HDR>
  </PropertyGroup>
