    <CNCGZH_DEP_BENCHMARK Condition="'$(CNCGZH_DEP_BENCHMARK)'==''">$([System.Environment]::GetEnvironmentVariable('CNCGZH_DEP_BENCHMARK'))</CNCGZH_DEP_BENCHMARK>
