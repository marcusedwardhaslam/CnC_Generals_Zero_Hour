    <CNCGZH_DEP_BINK Condition="'$(CNCGZH_DEP_BINK)'==''">$([System.Environment]::GetEnvironmentVariable('CNCGZH_DEP_BINK'))</CNCGZH_DEP_BINK>
    <CNCGZH_DEP_SAFEDISK_COMMON Condition="'$(CNCGZH_DEP_SAFEDISK_COMMON)'==''">$([System.Environment]::GetEnvironmentVariable('CNCGZH_DEP_SAFEDISK_COMMON'))</CNCGZH_DEP_SAFEDISK_COMMON>
    <CNCGZH_DEP_SAFEDISK_LAUNCHER Condition="'$(CNCGZH_DEP_SAFEDISK_LAUNCHER)'==''">$([System.Environment]::GetEnvironmentVariable('CNCGZH_DEP_SAFEDISK_LAUNCHER'))</CNCGZH_DEP_SAFEDISK_LAUNCHER>
    <CNCGZH_DEP_ASIMP3 Condition="'$(CNCGZH_DEP_ASIMP3)'==''">$([System.Environment]::GetEnvironmentVariable('CNCGZH_DEP_ASIMP3'))</CNCGZH_DEP_ASIMP3>
    <CNCGZH_DEP_GAMESPY Condition="'$(CNCGZH_DEP_GAMESPY)'==''">$([System.Environment]::GetEnvironmentVariable('CNCGZH_DEP_GAMESPY'))</CNCGZH_DEP_GAMESPY>
    <CNCGZH_DEP_ZLIB Condition="'$(CNCGZH_DEP_ZLIB)'==''">$([System.Environment]::GetEnvironmentVariable('CNCGZH_DEP_ZLIB'))</CNCGZH_DEP_ZLIB>
